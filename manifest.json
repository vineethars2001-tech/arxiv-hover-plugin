{
  "manifest_version": 3,
  "name": "arXiv Abstract Hover",
  "version": "3.0",
  "description": "Hover any arXiv link — see abstract, authors, and GitHub implementations instantly.",
  "permissions": ["scripting"],
  "host_permissions": [
    "https://export.arxiv.org/*",
    "https://api.github.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
